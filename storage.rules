rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'admin@seahcm.app';
    }
    function isVocUser() {
      return request.auth != null &&
        (request.auth.token.email == 'voc@seahcm.app' || request.auth.token.email == 'admin@seahcm.app');
    }

    match /specs/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /defects/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /complaints/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin() || isVocUser();
    }

    match /feasibility/{allPaths=**} {
      allow read: if true;
      // 첨부파일 업로드(신규 등록)는 누구나 가능, 삭제는 관리자만
      // (App Check/reCAPTCHA가 봇 차단. request.resource != null 이면 업로드, null 이면 삭제)
      allow write: if isAdmin() || request.resource != null;
    }

    match /certifications/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
