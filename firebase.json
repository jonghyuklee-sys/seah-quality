{
    "firestore": {
        "rules": "firestore.rules"
    },
    "storage": [{
        "bucket": "seah-quality2.firebasestorage.app",
        "rules": "storage.rules"
    }],
    "functions": {
        "source": "functions"
    },
    "hosting": {
        "site": "seahqm",
        "public": "hosting-shell",
        "ignore": ["**/.*"],
        "rewrites": [{
            "source": "**",
            "run": {
                "serviceId": "seahcm-qhub",
                "region": "asia-northeast3"
            }
        }]
    }
}
